  "properties": {
    "candidate_id": {"type": "string", "minLength": 1}, "territory": {"type": "string", "minLength": 1}, "customer": {"type": "string", "minLength": 1}, "payer": {"type": "string", "minLength": 1}, "trigger_event": {"type": "string", "minLength": 1}, "problem": {"type": "string", "minLength": 1}, "first_value_workflow": {"type": "string", "minLength": 1},
