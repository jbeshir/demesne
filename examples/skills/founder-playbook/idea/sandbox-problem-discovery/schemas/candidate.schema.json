    "scores": {"type": "object", "required": ["pain_magnitude_recurrence", "evidence_strength", "channel_accessibility", "pilot_clarity", "competitive_stagnation_whitespace", "implementation_burden", "continuing_manual_burden"], "additionalProperties": false, "properties": {
      "pain_magnitude_recurrence": {"type": "integer", "minimum": 0, "maximum": 5}, "evidence_strength": {"type": "integer", "minimum": 0, "maximum": 5}, "channel_accessibility": {"type": "integer", "minimum": 0, "maximum": 5}, "pilot_clarity": {"type": "integer", "minimum": 0, "maximum": 5}, "competitive_stagnation_whitespace": {"type": "integer", "minimum": 0, "maximum": 5}, "implementation_burden": {"type": "integer", "minimum": 0, "maximum": 5}, "continuing_manual_burden": {"type": "integer", "minimum": 0, "maximum": 5}
    }},
    "score_basis": {"type": "object", "required": ["pain_magnitude_recurrence", "evidence_strength", "channel_accessibility", "pilot_clarity", "competitive_stagnation_whitespace", "implementation_burden", "continuing_manual_burden"], "additionalProperties": false, "properties": {
      "pain_magnitude_recurrence": {"$ref": "#/$defs/basis"}, "evidence_strength": {"$ref": "#/$defs/basis"}, "channel_accessibility": {"$ref": "#/$defs/basis"}, "pilot_clarity": {"$ref": "#/$defs/basis"}, "competitive_stagnation_whitespace": {"$ref": "#/$defs/basis"}, "implementation_burden": {"$ref": "#/$defs/basis"}, "continuing_manual_burden": {"$ref": "#/$defs/basis"}
    }},
    "competitive_stagnation": {"type": "object", "required": ["basis_class", "claim_ids", "citations"], "properties": {"basis_class": {"enum": ["unknown", "absence-only", "exact-job-mismatch", "longitudinal-unresolved"]}, "claim_ids": {"type": "array", "items": {"type": "string", "minLength": 1}}, "citations": {"type": "array", "items": {"type": "string", "minLength": 1}}}},
    "barrier_decomposition": {"type": "object", "required": ["build_complexity", "external_permissions_data", "expert_judgment", "procurement_channel", "continuing_manual_burden", "unit_economics"], "additionalProperties": false, "properties": {"build_complexity": {"$ref":"#/$defs/barrier"}, "external_permissions_data": {"$ref":"#/$defs/barrier"}, "expert_judgment": {"$ref":"#/$defs/barrier"}, "procurement_channel": {"$ref":"#/$defs/barrier"}, "continuing_manual_burden": {"$ref":"#/$defs/barrier"}, "unit_economics": {"$ref":"#/$defs/barrier"}}}
  },
  "$defs": {"basis": {"type": "object", "required": ["claim_ids", "citations"], "properties": {"claim_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "citations": {"type": "array", "items": {"type": "string", "minLength": 1}}}},"barrier":{"type":"object","required":["assessment","claim_ids","citations","strong_builder_prior_applied","hard_red_line_id"],"additionalProperties":false,"properties":{"assessment":{"type":"string","minLength":1},"claim_ids":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"citations":{"type":"array","items":{"type":"string","minLength":1}},"strong_builder_prior_applied":{"type":"boolean"},"hard_red_line_id":{"type":["string","null"]}}}}, "additionalProperties": true
}
