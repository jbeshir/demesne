{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "integration_status", "candidates"],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1}, "integration_status": {"enum": ["not-integrated", "integrated"]},
    "candidates": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["candidate_id", "report_path", "report_sha256", "report_attestation_path", "disposition", "external_identities", "archive_neighbors", "repository_recommendation"], "properties": {
      "candidate_id": {"type": "string", "minLength": 1}, "report_path": {"type": "string", "minLength": 1}, "report_sha256": {"type": "string", "minLength": 1},
      "disposition": {"enum":["advance","evidence-insufficient","reject","dedup","supersede"]}, "external_identities": {"type": "array", "items": {"type":"object","required":["identity_type","value","source"],"additionalProperties":false,"properties":{"identity_type":{"enum":["track-id","alias","slug","stable-label"]},"value":{"type":"string","minLength":1},"source":{"type":"string","minLength":1}}}},
      "report_attestation_path":{"type":"string","minLength":1},
      "archive_neighbors": {"type": "array", "items": {"type": "string", "minLength": 1}}, "repository_recommendation": {"enum": ["create", "append", "supersede"]}
    }} }
  }
}
