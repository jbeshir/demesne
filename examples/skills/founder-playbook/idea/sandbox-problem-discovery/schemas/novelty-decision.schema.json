{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["record_id", "sequence", "recorded_at", "candidate_id", "comparison_ref", "inventory_digest", "neighbors", "outcome", "mechanism_delta", "basis", "prior_decision_digest"],
  "properties": {
    "record_id": {"type": "string", "minLength": 1}, "sequence":{"type":"integer","minimum":1}, "recorded_at":{"type":"string","minLength":1}, "candidate_id": {"type": "string", "minLength": 1},
    "inventory_digest":{"type":"string","minLength":1}, "prior_decision_digest":{"type":["string","null"]},
    "comparison_ref": {"type": "string", "minLength": 1}, "neighbors": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "outcome": {"enum": ["keep", "dedup", "supersede"]}, "mechanism_delta": {"type": "string", "minLength": 1}, "basis": {"type": "string", "minLength": 1}
  }
}
