{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "contract_sha256", "next_skill", "mount_one_brief_per_run", "authorization_limits", "finalists"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "next_skill": {"const":"sandbox-hypothesis-stress-test"},
    "mount_one_brief_per_run": {"const":true},
    "contract_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "authorization_limits": {"type": "array", "items": {"type": "string"}},
    "finalists": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["candidate_id", "decision", "report_path", "report_sha256", "evidence_vector", "hard_red_line_findings", "targeted_jobs"],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "decision": {"enum": ["advance", "evidence-insufficient", "reject"]},
          "report_path": {"type": "string", "minLength": 1},
          "report_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "brief_path": {"type": "string", "minLength": 1},
          "brief_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "hard_red_line_findings": {"type":"array","items":{"type":"string"}},
          "evidence_vector": {
            "type": "object",
            "required": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8"],
            "additionalProperties": false,
            "properties": {
              "G1": {"enum": ["A", "B", "C", "D", "E"]}, "G2": {"enum": ["A", "B", "C", "D", "E"]},
              "G3": {"enum": ["A", "B", "C", "D", "E"]}, "G4": {"enum": ["A", "B", "C", "D", "E"]},
              "G5": {"enum": ["A", "B", "C", "D", "E"]}, "G6": {"enum": ["A", "B", "C", "D", "E"]},
              "G7": {"enum": ["A", "B", "C", "D", "E"]}, "G8": {"enum": ["A", "B", "C", "D", "E"]}
            }
          },
          "targeted_jobs": {
            "type": "object", "required": ["round_1", "round_2"], "additionalProperties": false,
            "properties": {"round_1": {"type": "integer", "minimum": 0, "maximum": 4}, "round_2": {"type": "integer", "minimum": 0, "maximum": 2}}
          },
          "unresolved_gaps": {"type": "array", "items": {"type": "string"}}
        },
        "allOf": [{"if":{"properties":{"decision":{"const":"advance"}}},"then":{"required":["brief_path","brief_sha256"]}}],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
