{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "bundle_id", "created_at", "immutable", "contract_sha256", "catalog_path", "catalog_sha256", "artifacts"],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1}, "bundle_id": {"type": "string", "minLength": 1}, "created_at": {"type": "string", "minLength": 1},
    "immutable": {"const": true}, "contract_sha256": {"type": "string", "minLength": 1}, "catalog_path": {"type": "string", "minLength": 1}, "catalog_sha256": {"type": "string", "minLength": 1},
    "artifacts": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "minLength": 1}}}}
  }
}
