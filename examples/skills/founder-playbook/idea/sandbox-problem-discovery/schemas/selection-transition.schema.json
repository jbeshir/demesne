{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["record_id", "candidate_id", "occurred_at", "from", "to", "cause", "claim_ids", "citations"],
  "properties": {
    "record_id": {"type": "string", "minLength": 1}, "candidate_id": {"type": "string", "minLength": 1}, "occurred_at": {"type": "string", "minLength": 1},
    "from": {"type": ["string", "null"]}, "to": {"type": "string", "minLength": 1}, "cause": {"type": "string", "minLength": 1},
    "claim_ids": {"type": "array", "minItems":1, "items": {"type": "string", "minLength": 1}}, "citations": {"type": "array", "minItems":1, "items": {"type": "string", "minLength": 1}}
  }
}
