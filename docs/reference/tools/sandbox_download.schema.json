{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jbeshir/demesne/docs/reference/tools/sandbox_download.schema.json",
  "title": "sandbox_download input",
  "type": "object",
  "properties": {
    "sandbox_id": {
      "type": "string",
      "description": "Sandbox handle returned by sandbox_create."
    },
    "src": {
      "type": "string",
      "description": "Absolute path inside the sandbox to download."
    }
  },
  "required": ["sandbox_id", "src"],
  "additionalProperties": false
}
