# Copy to .env and fill in. Consumed by `make test-integration` and useful
# for ad-hoc runs of `./bin/demesne-mcp` against a local OpenSandbox.

# OpenSandbox lifecycle server. Defaults match `uvx opensandbox-server`'s
# example docker config.
OPEN_SANDBOX_DOMAIN=127.0.0.1:8080
OPEN_SANDBOX_PROTOCOL=http
OPEN_SANDBOX_API_KEY=

# Demesne config — only needed when running the binary, not the test.
DEMESNE_ALLOWED_PATHS=/tmp/demesne-test
DEMESNE_OUTPUT_ROOT=/tmp/demesne/out

# sandbox_agent and sandbox_research require this. Generate with
# `claude setup-token` on the host. Leave blank to disable the agent
# and research tools; other tools still work.
DEMESNE_CLAUDE_CODE_OAUTH_TOKEN=
