# Copy to .env and fill in. Consumed by `make test-integration` and useful
# for ad-hoc runs of `./bin/demesne-mcp` against a local OpenSandbox.

# OpenSandbox lifecycle server. Defaults match `uvx opensandbox-server`'s
# example docker config.
OPEN_SANDBOX_DOMAIN=127.0.0.1:8080
OPEN_SANDBOX_PROTOCOL=http
OPEN_SANDBOX_API_KEY=

# Demesne config — only needed when running the binary, not the test.
DEMESNE_ALLOWED_PATHS=/tmp/demesne-test
DEMESNE_OUTPUT_ROOT=/tmp/demesne/out

# sandbox_agent and sandbox_research require this. Generate with
# `claude setup-token` on the host. Leave blank to disable the agent
# and research tools; other tools still work.
DEMESNE_CLAUDE_CODE_OAUTH_TOKEN=

# Codex provider auth file (only needed for sandbox_agent with agent="codex").
# Default: ~/.codex/auth.json (produced by `codex login`).
#DEMESNE_CODEX_AUTH_FILE=

# Host MCP proxy (optional). demesne discovers stdio MCP servers from both
# your Claude Code config and your Codex config, merges them (Codex wins on
# conflict), and exposes their read-only tools to agents.
# Defaults: ~/.claude.json for Claude Code discovery, ~/.codex/config.toml for
# Codex discovery, ~/.config/demesne/mcp-allowlist.json for the tool allowlist
# (auto-seeded on first run). The aggregator listens on a unix socket
# (bind-mounted into each sandbox sidecar), default /tmp/demesne-mcp/aggregator.sock.
#DEMESNE_CLAUDE_CODE_MCP_CONFIG=
#DEMESNE_CODEX_MCP_CONFIG=
#DEMESNE_MCP_ALLOWLIST=
#DEMESNE_MCP_SOCKET=
